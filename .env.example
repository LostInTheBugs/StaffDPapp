# Staff Delegation — Environment Variables
# Copier ce fichier en .env et adapter

# Secret key for JWT signing (generate: openssl rand -hex 32)
SD_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Database URL (SQLite for dev, PostgreSQL for prod)
SD_DATABASE_URL=sqlite:///./data/staff_delegation.db

# Token expiration in minutes (default: 1440 = 24h)
SD_ACCESS_TOKEN_EXPIRE_MINUTES=1440
